  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "build": "tsc --noEmit && vite build",
    "clean": "rimraf dist .vite node_modules/.vite node_modules/.cache .cache .parcel-cache coverage",
    "clean:soft": "rimraf dist .vite node_modules/.vite node_modules/.cache",
    "clean:hard": "rimraf dist .vite node_modules/.vite node_modules/.cache .cache .parcel-cache coverage package-lock.json && rimraf node_modules",
    "build:force": "tsc --noEmit && vite build --force",
    "clean-build": "npm run clean && npm ci && npm run build",
    "prebuild": "node -e \"process.exit(0)\""
    
    
